# ════════════════════════════════════════════════════════════════
#  RedFlag 2.1 — Production Environment Variables
#  Copia este archivo: cp .env.production.example .env.production
#  Edita con tus valores reales antes de hacer deploy
# ════════════════════════════════════════════════════════════════

# ── Dominio ───────────────────────────────────────────────────────
DOMAIN=redflag.example.com
GRAFANA_PASSWORD=cambia_esta_password_segura

# ── Nodos RedFlag ──────────────────────────────────────────────────
PORT_NODE1=8545
PORT_NODE2=8546
P2P_PORT_NODE1=9000
P2P_PORT_NODE2=9001
RUST_LOG=warn

# ── Bridge ─────────────────────────────────────────────────────────
BRIDGE_PORT=8547
BRIDGE_POLL_SECS=12
BRIDGE_CONFIRMATIONS=3
BRIDGE_MAX_AMOUNT=1000000
# Secreto compartido entre el relayer y el nodo para autorizar mint
BRIDGE_MINT_SECRET=genera_un_secreto_aleatorio_seguro_aqui

# ── EVM RPCs (obtén keys gratis en alchemy.com) ──────────────────
ETH_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/TU_ALCHEMY_KEY
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
POLYGON_AMOY_RPC=https://polygon-amoy.g.alchemy.com/v2/TU_ALCHEMY_KEY

# ── Bridge Contracts (después de deploy con deploy_contracts.sh) ──
# ETH_SEPOLIA_BRIDGE_CONTRACT=0x...
# BSC_TESTNET_BRIDGE_CONTRACT=0x...
# POLYGON_AMOY_BRIDGE_CONTRACT=0x...

# ── Clave EVM del relayer (para firmar unlock en contratos EVM) ───
# BRIDGE_RELAYER_PRIVATE_KEY=0x_tu_clave_privada_eth_sin_fondos_en_mainnet

# ── Clave RedFlag del relayer (para el mint de RF nativo) ─────────
# BRIDGE_RF_PRIVATE_KEY=hex_de_tu_keypair_ml_dsa_serializado
