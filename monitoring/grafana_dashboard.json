{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "title": "redflag.web3 — Blockchain Dashboard",
  "uid": "redflag21",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Current Round",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "datasource": "DS_PROMETHEUS", "expr": "redflag_round", "legendFormat": "Round" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#ef4444", "mode": "fixed" }, "unit": "short" } }
    },
    {
      "id": 2, "type": "stat", "title": "Total Transactions",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "datasource": "DS_PROMETHEUS", "expr": "redflag_tx_count", "legendFormat": "TXs" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#00e878", "mode": "fixed" }, "unit": "short" } }
    },
    {
      "id": 3, "type": "stat", "title": "Committed Vertices",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "datasource": "DS_PROMETHEUS", "expr": "redflag_committed_vertices", "legendFormat": "Committed" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#00d4ff", "mode": "fixed" }, "unit": "short" } }
    },
    {
      "id": 4, "type": "stat", "title": "Active Validators",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "datasource": "DS_PROMETHEUS", "expr": "redflag_validator_count", "legendFormat": "Validators" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#f59e0b", "mode": "fixed" }, "unit": "short" } }
    },
    {
      "id": 5, "type": "stat", "title": "Pending TXs (Mempool)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "datasource": "DS_PROMETHEUS", "expr": "redflag_pending_txs", "legendFormat": "Pending" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }, "unit": "short" } }
    },
    {
      "id": 6, "type": "stat", "title": "Uptime",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "datasource": "DS_PROMETHEUS", "expr": "redflag_uptime_seconds", "legendFormat": "Uptime" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#7c3aed", "mode": "fixed" }, "unit": "s" } }
    },
    {
      "id": 10, "type": "graph", "title": "TPS — Transactions Per Second",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "DS_PROMETHEUS",
        "expr": "rate(redflag_tx_count[1m])",
        "legendFormat": "TPS Node 1"
      }, {
        "datasource": "DS_PROMETHEUS",
        "expr": "rate(redflag_tx_count{instance=\"node2\"}[1m])",
        "legendFormat": "TPS Node 2"
      }],
      "yaxes": [{ "format": "short", "label": "TX/s" }, { "format": "short" }],
      "lines": true, "linewidth": 2, "fill": 1,
      "aliasColors": { "TPS Node 1": "#ef4444", "TPS Node 2": "#00e878" }
    },
    {
      "id": 11, "type": "graph", "title": "Consensus Round Progress",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "DS_PROMETHEUS",
        "expr": "redflag_round",
        "legendFormat": "Round {{instance}}"
      }],
      "yaxes": [{ "format": "short", "label": "Round" }, { "format": "short" }],
      "lines": true, "linewidth": 2, "fill": 0
    },
    {
      "id": 20, "type": "graph", "title": "Fee Pool Balance",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "targets": [{ "datasource": "DS_PROMETHEUS", "expr": "redflag_fee_pool_balance", "legendFormat": "Fee Pool (RF)" }],
      "yaxes": [{ "format": "short", "label": "RF" }, { "format": "short" }],
      "lines": true, "linewidth": 2, "fill": 1,
      "aliasColors": { "Fee Pool (RF)": "#f59e0b" }
    },
    {
      "id": 21, "type": "graph", "title": "Faucet Remaining",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 6 },
      "targets": [{ "datasource": "DS_PROMETHEUS", "expr": "redflag_faucet_balance", "legendFormat": "Faucet (RF)" }],
      "yaxes": [{ "format": "short", "label": "RF" }, { "format": "short" }],
      "lines": true, "linewidth": 2, "fill": 1,
      "aliasColors": { "Faucet (RF)": "#00d4ff" }
    },
    {
      "id": 22, "type": "graph", "title": "Total Accounts",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 6 },
      "targets": [{ "datasource": "DS_PROMETHEUS", "expr": "redflag_account_count", "legendFormat": "Accounts" }],
      "yaxes": [{ "format": "short", "label": "Accounts" }, { "format": "short" }],
      "lines": true, "linewidth": 2, "fill": 1,
      "aliasColors": { "Accounts": "#00e878" }
    }
  ]
}
